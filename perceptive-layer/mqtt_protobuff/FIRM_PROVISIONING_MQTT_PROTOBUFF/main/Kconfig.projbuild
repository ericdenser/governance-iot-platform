menu "WiFi Manager Configuration"

    config WIFI_SSID
        string "Main SSID"
        default "Myssid"

    config WIFI_PASSWORD
        string "Main Password"
        default "Mypassword"

    config WIFI_MAX_RETRIES
        int "Max Retries"
        default 5

    choice WIFI_FAILURE_STRATEGY
        prompt "Recovery Strategy on Failure"
        default WIFI_RECOVERY_RESET
        help
            Define o comportamento quando o número máximo de tentativas é atingido.

        config WIFI_RECOVERY_RESET
            bool "System Reset"
            help
                Reinicia o ESP32 automaticamente (esp_restart).

        config WIFI_RECOVERY_SWAP
            bool "Swap SSID (Try Backup Network)"
            help
                Tenta conectar em uma rede secundária definida abaixo.
                Se a rede secundária também falhar, o sistema reinicia.

        config WIFI_RECOVERY_NONE
            bool "Keep Idle (Manual Handling)"
            help
                Apenas para o driver e define o estado como FAILED.
                A aplicação deve decidir o que fazer.
    endchoice

    # CREDENCIAIS DE BACKUP (Só aparecem se SWAP for escolhido)
    config WIFI_BACKUP_SSID
        string "Backup SSID"
        depends on WIFI_RECOVERY_SWAP
        default "Backup_Network"

    config WIFI_BACKUP_PASSWORD
        string "Backup Password"
        depends on WIFI_RECOVERY_SWAP
        default ""

endmenu

menu "Governance IoT"

    config GOV_MQTT_BROKER_URI
        string "MQTT Broker URI"
        default "mqtts://xxx.xxx.xx.xx:8883"
        help
            URI completa do broker MQTT. O esquema define o transporte:
              mqtts://host:8883        — TLS direto 
              mqtt://host:1883         — sem TLS 
            Exemplos:
              mqtts://xxx.xxx.xx.xx:8883
              mqtts://iot.mackenzie.br:8883

    config GOV_MDM_BASE_URL
        string "MDM (govApi) base URL"
        default "http://xxx.xxx.xx.xx:8080"
        help
            URL base do govApi, SEM barra final. Os endpoints
            (/provisioning/activate etc) são concatenados pelo firmware.
            Exemplos:
              http://xxx.xxx.xx.xx:8080
              https://mackenzie.br/apps/govApi
              https://iot.mackenzie.br

endmenu