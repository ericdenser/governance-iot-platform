menu "WiFi Manager Configuration"

    config WIFI_SSID
        string "Main SSID"
        default "Myssid"

    config WIFI_PASSWORD
        string "Main Password"
        default "Mypassword"

    config WIFI_MAX_RETRIES
        int "Max Retries"
        default 5

    choice WIFI_FAILURE_STRATEGY
        prompt "Recovery Strategy on Failure"
        default WIFI_RECOVERY_RESET
        help
            Define o comportamento quando o número máximo de tentativas é atingido.

        config WIFI_RECOVERY_RESET
            bool "System Reset"
            help
                Reinicia o ESP32 automaticamente (esp_restart).

        config WIFI_RECOVERY_SWAP
            bool "Swap SSID (Try Backup Network)"
            help
                Tenta conectar em uma rede secundária definida abaixo.
                Se a rede secundária também falhar, o sistema reinicia.

        config WIFI_RECOVERY_NONE
            bool "Keep Idle (Manual Handling)"
            help
                Apenas para o driver e define o estado como FAILED.
                A aplicação deve decidir o que fazer.
    endchoice

    # CREDENCIAIS DE BACKUP (Só aparecem se SWAP for escolhido)
    config WIFI_BACKUP_SSID
        string "Backup SSID"
        depends on WIFI_RECOVERY_SWAP
        default "Backup_Network"

    config WIFI_BACKUP_PASSWORD
        string "Backup Password"
        depends on WIFI_RECOVERY_SWAP
        default ""

endmenu

menu "Governance IoT"

    config GOV_MQTT_BROKER_URI
        string "MQTT Broker URI"
        default "mqtt://REPLACE_ME:1883"
        help
            URI completa do broker MQTT. O esquema define o transporte:
              mqtt://host:8883        — TLS direto
              wss://host:1883         — MQTT-over-Websocket
            Exemplos:
              mqtt://192.168.15.76:1883 (dev local)
              wss://iot.mackenzie.br/mqtt (prod via websocket)


    config GOV_KEYCLOAK_URL
        string "Keycloak base URL"
        default "http://REPLACE_ME:8080"
        help
            Base URL do Keycloak (SEM /realms/... no final).
            Obter JWT via client_credentials.
            Exemplos:
              http://mackleaps.mackenzie.br/keycloak
              http://192.168.15.76:8080

    config GOV_KEYCLOAK_REALM
        string "Keycloak realm"
        default "IOT-REALM"
        help
            Realm onde os device-clients existem.

    config GOV_KC_TOKEN_MARGIN_S
        int "JWT renewal margin (seconds)"
        default 300
        range 30 1800
        help
            Margem de segurança antes do exp: renova JWT quando faltar
            menos que isso pra expirar. Default 300 (5min) evita usar
            token que expira durante o handshake MQTT.

    config GOV_GPS_POWER_PIN
        int "GPS power control GPIO"
        default 5
        help
            GPIO que controla o transistor PNP de alimentação do módulo GPS.
            Level 1 = GPS ligado, level 0 = desligado.

    config GOV_GPS_UART_TX_PIN
        int "GPS UART TX GPIO (ESP TX → GPS RX)"
        default 17

    config GOV_GPS_UART_RX_PIN
        int "GPS UART RX GPIO (ESP RX ← GPS TX)"
        default 18

    config GOV_GPS_UART_PORT
        int "GPS UART port number"
        default 1

    config GOV_TELEMETRY_INTERVAL_MS
        int "Telemetry publish interval (ms)"
        default 5000

    config GOV_STATUS_INTERVAL_MS
        int "Status publish interval (ms)"
        default 30000

    config GOV_MAX_WIFI_RETRIES
        int "Max WiFi connect retries antes de setar erro"
        default 10

    config GOV_MAX_CRASH_COUNT
        int "Max crash count antes de invalidar firmware"
        default 3

    config GOV_GPS_SYNC_EVERY_N_BOOTS
        int "Corrigir DS3231 com GPS a cada N boots"
        default 24

    config GOV_EXTERNAL_TIME_TIMEOUT_MS
        int "Timeout do get_external_time hook (ms)"
        default 45000
        help
            Tempo máximo que o hook get_external_time tem pra obter hora.
            Cold start de GPS pode passar de 30s. Aumenta se GPS demora
            demais no boot inicial (ou considera ligar o GPS antes de
            governance_core_init pra warm start).

    config GOV_OTA_JITTER_MAX_MS
        int "OTA download jitter maximo (ms)"
        default 10000
        help
            Atraso aleatorio (0..N ms) antes de iniciar o download OTA.
            Espalha os downloads de uma wave para nao saturar o object storage quando varios
            devices recebem o comando no mesmo instante. 0 desativa o jitter.
endmenu

